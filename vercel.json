{
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/review", "destination": "/review.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}
